<form style="display: flex; flex-direction: column; height: 100%; width: 100%;">
	<header class="sheet-header">
		<div class="header-details">
			<h1 class="charname">yugen-party</h1>
		</div>
	</header>

	<div class="yugen-config-body">
		<div class="form-group">
			<label>{{localize "yugen-party.config.macro-label"}}</label>
			<select name="macroId">
				<option value="">-- None --</option>
				{{#each macros}}
				<option value="{{this.id}}" {{#if (eq this.id ../resource.macroId)}}selected{{/if}}>{{this.name}}</option>
				{{/each}}
			</select>
		</div>
		<div class="form-group">
			<label>{{localize "yugen-party.config.script-label"}}</label>
			<textarea name="script" placeholder="const token = canvas.tokens.controlled[0]; ...">{{resource.script}}</textarea>
		</div>
	</div>

	<div class="sheet-footer">
		<button type="submit">
			<i class="fas fa-save"></i> {{localize "yugen-party.config.save-action-btn"}}
		</button>
	</div>
</form>
