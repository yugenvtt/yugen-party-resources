{
	"name": "yugen-party",
	"version": "2.0.0",
	"description": "Party UI, Custom Pause Menu, Party Resources Manager, and a DMMd, Persona, and Baldur's Gate 3 inspired party sidebar and resources bar for Foundry VTT.",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"build": "PATH=$PATH:$(pwd)/node_modules/typescript/bin:$(pwd)/node_modules/vite/bin vite build && node ./node_modules/ts-node/dist/bin.js build/post-build.ts",
		"dev": "PATH=$PATH:$(pwd)/node_modules/typescript/bin:$(pwd)/node_modules/vite/bin vite build --watch",
		"lint": "node ./node_modules/eslint/bin/eslint.js --config .eslint.config.mjs src/**/*.ts",
		"lint:fix": "node ./node_modules/eslint/bin/eslint.js --config .eslint.config.mjs src/**/*.ts --fix",
		"prettier:format": "prettier --write \"src/**/*.ts\"",
		"clean": "node ./node_modules/ts-node/dist/bin.js build/clean.ts",
		"link": "node ./node_modules/ts-node/dist/bin.js build/link.ts"
	},
	"author": "yugen.",
	"license": "MIT",
	"devDependencies": {
		"@league-of-foundry-developers/foundry-vtt-types": "^12.331.5",
		"@types/archiver": "^7.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^20.11.24",
		"@typescript-eslint/eslint-plugin": "^8.5.0",
		"@typescript-eslint/parser": "^8.5.0",
		"archiver": "^7.0.1",
		"dotenv": "^16.4.5",
		"eslint": "^9.10.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"fs-extra": "^11.2.0",
		"prettier": "^3.3.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.5.0",
		"vite": "^6.0.1",
		"vite-plugin-checker": "^0.8.0",
		"vite-plugin-terminal": "^1.4.0"
	}
}
